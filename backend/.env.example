PORT=3000
NODE_ENV=production

# URL publica del backend en Render, sin /api
PUBLIC_API_URL=https://renovared-backend.onrender.com

# URL publica del frontend en Render
FRONTEND_URL=https://renovared-frontend.onrender.com

# Alternativa si necesitás varios orígenes
# CORS_ORIGINS=https://renovared-frontend.onrender.com,https://www.tudominio.com

JWT_SECRET=definir_un_secreto_seguro
GOOGLE_CLIENT_ID=

# Base de datos
# Opcion 1: usar DATABASE_URL
DATABASE_URL=

# Opcion 2: usar parametros individuales
DB_HOST=
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASSWORD=

# SSL de PostgreSQL: true para Supabase / false para Render internal DB
DB_SSL=true
DB_LOGGING=false

# Mercado Pago
ACCESS_TOKEN_MP=
MP_ACCESS_TOKEN=
MERCADOPAGO_ACCESS_TOKEN=
MP_ACCESS_TOKEN_BY_USER=
MP_WEBHOOK_URL=
PAYMENT_HOLDER=RenovaRed
